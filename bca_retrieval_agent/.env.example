# BCA Retrieval Agent — Environment Configuration
# Copy this file to .env and fill in optional API keys.

# --- Search APIs (optional — DuckDuckGo fallback works without keys) ---
SERPAPI_KEY=
BING_SEARCH_API_KEY=

# --- LLM APIs (optional — rule-based classification works without keys) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- HTTP / Crawl Settings ---
USER_AGENT=BCA-Retrieval-Agent/1.0 (transportation research)
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=1.0
MAX_CRAWL_DEPTH=2
MAX_CRAWL_PAGES=50
